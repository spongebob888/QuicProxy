[Unit]
Description=QuicProxy Server
After=network.target

[Service]
Type=simple
# User=ubuntu
WorkingDirectory=/home/ubuntu/quicproxy
ExecStart=/home/ubuntu/quicproxy/quicproxy -c /home/ubuntu/quicproxy/server.json5
Restart=on-failure
RestartSec=5
LimitNOFILE=infinity
LimitNPROC=infinity
TasksMax=infinity

[Install]
WantedBy=multi-user.target
